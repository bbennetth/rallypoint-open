# --- Server ----------------------------------------------------------
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Where the hosted Rallypoint ID UI lives. The API's UI namespace
# (/api/v1/ui/*) only accepts requests with a matching Origin
# header (slice 0 design doc).
UI_ORIGIN=http://localhost:5173

# Comma-separated allowlist of origins permitted to call the
# /api/v1/sdk/* namespace (CORS preflight). Empty = no SDK callers.
SDK_CORS_ALLOWED_ORIGINS=

PUBLIC_BASE_URL=http://localhost:8080

# Session cookie name. Defaults derived from NODE_ENV:
#   production  -> __Host-rp_session  (Secure-only, Path=/, no Domain)
#   dev / test  -> rp_session         (Firefox/Safari silently drop
#                                       __Host- cookies on http://localhost)
# Operators with a custom hostname strategy can override here.
# SESSION_COOKIE_NAME=__Host-rp_session

# CSRF cookie name. Same env semantics as SESSION_COOKIE_NAME.
#   production -> __Host-rp_csrf
#   dev / test -> rp_csrf
# CSRF_COOKIE_NAME=__Host-rp_csrf

# Trust policy for IP-extraction headers (#33). Drives audit-log
# IPs + per-IP rate-limit buckets.
#   legacy           — leftmost XFF, then cf-connecting-ip, then 0.0.0.0
#                      (safe behind a single trusted reverse proxy)
#   xff              — leftmost XFF only, no fallback
#   cf-connecting-ip — Cloudflare deploys; ignore XFF entirely
#   none             — no proxy at all; ignore forwarded headers
#                      (use the socket address)
TRUSTED_PROXY_HEADER=legacy

# --- Database --------------------------------------------------------
# All apps use Cloudflare D1 (SQLite) via wrangler bindings — there is
# no DATABASE_URL. Locally, `wrangler dev` serves a local D1 and applies
# migrations at startup. (Postgres + DATABASE_URL were removed with the
# Docker dev stack; CF-native local stack tracked in issue #403.)

# --- Secrets (replace before any non-dev deploy!) -------------------
# Pepper applied (HMAC-SHA256) to passwords before argon2. Rotate
# by bumping ARGON2_PEPPER_VERSION and adding the new value
# server-side; per-row key_version selects which pepper to use.
ARGON2_PEPPER=dev-pepper-do-not-use-in-production-must-be-32+chars

# HMAC key for hashing session IDs at rest (defense in depth — the
# session table primary key is SHA-256(token), but if we ever switch
# to HMAC instead of bare SHA-256, this is the secret).
SESSION_HMAC_KEY=dev-session-hmac-do-not-use-in-production-32+chars

# HMAC key for hashing 2FA codes at rest (signin_challenges.code_hmac).
SIGNIN_CODE_HMAC_KEY=dev-signin-code-hmac-do-not-use-in-production-32+chars

# --- Mailer ----------------------------------------------------------
# 'resend' | 'smtp' | 'log'. 'smtp' expects a local SMTP sink (the old
# Docker stack ran Mailpit on :1025/:8025 — removed, see #403); use 'log'
# to print emails to the console until the dev stack is rebuilt.
MAILER=log
RESEND_API_KEY=

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Rallypoint ID <noreply@rallypoint.local>

# --- Captcha ---------------------------------------------------------
# 'turnstile' | 'allow' | 'deny'. Defaults below are Cloudflare's
# documented Turnstile test keys (always pass) so signup forms work
# without a Cloudflare account. Swap to real keys for production.
CAPTCHA=turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# --- HIBP (breached-password check) ---------------------------------
# 'hibp' (public k-anonymity API, no key required), 'stub' (always
# returns not-breached — DEV ONLY, prints a console.warn), or
# 'always-breached' (rejects every password — for tests).
BREACHED_PASSWORD_CHECK=hibp

# --- Admin (slice 5.5) ----------------------------------------------
# Long random string. Required to call /api/v1/admin/* endpoints.
# Leave empty to disable the admin namespace entirely.
ADMIN_TOKEN=

# --- Rallypoint Events (Phase B — first slice landed in #63) --------
# Events uses its own Cloudflare D1 binding (no connection URL).

# The hosted Events UI origin. Events API's /api/v1/ui/* namespace
# checks Origin against this value (slice 2 wires the middleware).
EVENTS_UI_ORIGIN=http://localhost:5174

# Rallypoint ID coordinates as seen from events-api. In docker
# compose these are the in-network DNS names; on the host they are
# localhost ports.
RPID_API_URL=http://localhost:8080
RPID_UI_URL=http://localhost:5173

# --- Cross-app SSO (Rallypoint Events #57) ---------------------------
# EVENTS_API_KEY: bearer presented by events-api on calls to RPID's
# /api/v1/sdk/sso/exchange. Min 32 chars. The SAME value must be set
# on every app that uses it (RPID reads it to authorise the caller;
# events-api reads it to compose the Authorization header; lists-api
# reads it as the peer key gating its /sdk/lists surface, which
# events-api presents for the crew-lists BFF proxy — #84). Empty =
# the gated endpoint returns 404 (anti-fingerprint, same posture as
# ADMIN_TOKEN). Generate with `openssl rand -base64 32`.
EVENTS_API_KEY=dev-events-api-key-do-not-use-in-production-32+chars

# SSO_EVENTS_HOST: bare host (no protocol) where the Events web
# client lives. RPID's /api/v1/ui/sso/code validates the body's
# return_to_host against this when client='events'. Dev:
# localhost:5174. Prod: events.rallypt.app. Empty = mint with
# client='events' returns 400 sso_client_unknown.
SSO_EVENTS_HOST=localhost:5174

# Object storage for map images (slice 5 owns the upload flow).
# The old Docker stack ran a MinIO container satisfying the S3
# contract; it was removed (see #403). Point at R2/S3 or a local
# emulator until the CF-native dev stack provides one.
EVENTS_OBJECT_STORE=minio
EVENTS_OBJECT_STORE_ENDPOINT=http://localhost:9000
EVENTS_OBJECT_STORE_REGION=us-east-1
EVENTS_OBJECT_STORE_BUCKET=rallypoint-events-dev
EVENTS_OBJECT_STORE_ACCESS_KEY=rallypoint
EVENTS_OBJECT_STORE_SECRET_KEY=rallypoint-dev-secret

# --- Rallypoint Lists (Phase C — first slice landed in #114) --------
# Lists uses its own Cloudflare D1 binding (no connection URL).

# The hosted Lists UI origin. Lists API's /api/v1/ui/* namespace
# checks Origin against this value.
LISTS_UI_ORIGIN=http://localhost:5175

# LISTS_API_URL: base origin of lists-api. Used by events-api for the
# crew-lists BFF proxy (#84) and by planner-api for the Task Lists BFF
# (#255, slice 6b). Each calls @rallypoint/lists-client server-to-server,
# presenting its own *_API_KEY to the /sdk/* gate. Defaults to the dev
# port if unset.
LISTS_API_URL=http://localhost:8082

# EVENTS_API_URL: base origin of events-api. Used by planner-api for the
# Personal Events BFF (#255, slice 7). planner-api calls
# @rallypoint/events-client server-to-server against the authenticated
# /sdk/personal-events surface, presenting PLANNER_API_KEY. Defaults to
# the dev port if unset.
EVENTS_API_URL=http://localhost:8081

# LISTS_API_KEY: bearer presented by lists-api on calls to RPID's
# /api/v1/sdk/sso/exchange. Min 32 chars. The SAME value must be set
# on BOTH apps (RPID accepts any configured per-app key; lists-api
# composes the Authorization header). Empty = exchange endpoint
# returns 404 (anti-fingerprint). Generate with `openssl rand -base64 32`.
LISTS_API_KEY=dev-lists-api-key-do-not-use-in-production-32+chars

# SSO_LISTS_HOST: bare host (no protocol) where the Lists web client
# lives. RPID's /api/v1/ui/sso/code validates return_to_host against
# this when client='lists'. Dev: localhost:5175. Prod:
# lists.rallypt.app. Empty = mint with client='lists' returns 400.
SSO_LISTS_HOST=localhost:5175

# REALTIME_TOKEN_HMAC_KEY: HMAC key for short-lived realtime channel
# tokens (#313, Phase 3). lists-api mints a token after the read-auth
# check; the RealtimeHub Durable Object verifies it on WebSocket
# connect/refresh. Min 32 chars; required in production. The WS path is
# only live once lists-api runs as a Worker (Phase 4) — on the Node dev
# stack the upgrade route 503s, so a dev default is supplied post-parse
# and this can stay unset locally. Generate with `openssl rand -base64 32`.
# REALTIME_TOKEN_HMAC_KEY=

# --- Rallypoint Money (Phase D — Money V1 epic #116) ---------------
# Money uses its own Cloudflare D1 binding (no connection URL).

# The hosted Money UI origin. Money API's /api/v1/ui/* namespace
# checks Origin against this value.
MONEY_UI_ORIGIN=http://localhost:5176

# MONEY_API_URL: base origin of money-api, used by events-api for the
# crew-ledger auto-attach + inline BFF read (#116). events-api calls
# @rallypoint/money-client server-to-server, presenting EVENTS_API_KEY
# to the /sdk/ledger gate. Defaults to the dev port if unset.
MONEY_API_URL=http://localhost:8083

# MONEY_API_KEY: bearer presented by money-api on calls to RPID's
# /api/v1/sdk/sso/exchange AND accepted by money-api's own /sdk
# namespace from events-api. Min 32 chars. The SAME value must be
# set on BOTH apps. Empty = exchange endpoint returns 404
# (anti-fingerprint), and money-api hard-fails at boot in prod.
# Generate with `openssl rand -base64 32`.
MONEY_API_KEY=dev-money-api-key-do-not-use-in-production-32+chars

# MONEY_SESSION_KEY_V1: session-token encryption key for money-api's
# own session cookies (independent of RPID's session). Min 32 chars.
# Hard-fails at boot in prod if unset. Generate with `openssl rand
# -base64 32`.
MONEY_SESSION_KEY_V1=dev-money-session-key-v1-not-real-rotate-before-prod

# SSO_MONEY_HOST: bare host (no protocol) where the Money web client
# lives. RPID's /api/v1/ui/sso/code validates return_to_host against
# this when client='money'. Dev: localhost:5176. Prod:
# money.rallypt.app. Empty = mint with client='money' returns 400.
SSO_MONEY_HOST=localhost:5176

# --- Rallypoint Planner (#255) ---------------------------------------
# Planner is a thin BFF (planner-api) + SPA (planner-web) over the Lists
# and Events SDKs; it owns no domain schema. Slice 0 only registers the
# 'planner' SSO client on RPID — the API_URL / UI_ORIGIN / SESSION_KEY
# vars land with the planner-api/planner-web slices.

# PLANNER_API_KEY: bearer presented by planner-api on calls to RPID's
# /api/v1/sdk/sso/exchange AND on its server-to-server calls to the
# lists-api / events-api /sdk namespaces. Min 32 chars. Empty =
# exchange endpoint returns 404 (anti-fingerprint). Generate with
# `openssl rand -base64 32`.
PLANNER_API_KEY=dev-planner-api-key-do-not-use-in-production-32+chars

# PLANNER_SESSION_KEY_V1: session-token encryption key for planner-api's
# own session cookies (independent of RPID's session). Min 32 chars.
# Hard-fails at boot in prod if unset. Generate with `openssl rand
# -base64 32`. Rotate by incrementing PLANNER_SESSION_KEY_VERSION and
# adding PLANNER_SESSION_KEY_V2, etc.
PLANNER_SESSION_KEY_V1=dev-planner-session-key-v1-not-real-rotate-before-prod

# PLANNER_UI_ORIGIN: the Planner web client origin (for CORS on
# /api/v1/ui/*). Dev: http://localhost:5177.
PLANNER_UI_ORIGIN=http://localhost:5177

# SSO_PLANNER_HOST: bare host (no protocol) where the Planner web
# client lives. RPID's /api/v1/ui/sso/code validates return_to_host
# against this when client='planner'. Dev: localhost:5177. Prod:
# planner.rallypt.app. Empty = mint with client='planner' returns 400.
SSO_PLANNER_HOST=localhost:5177

# VAPID keys for planner-api Web Push (Phase 1 — personal Events).
# Generate with `generateVapidKeys()` from @rallypoint/web-push (or
# `npx web-push generate-vapid-keys`).

# VAPID_PUBLIC_KEY: the public key (base64url, uncompressed P-256 point).
# Also exposed to planner-web as the build var VITE_VAPID_PUBLIC_KEY
# (the browser applicationServerKey). Set this as a repo Variable in CI
# so cf-deploy.yml can inject it at SPA build time.
VAPID_PUBLIC_KEY=dev-vapid-public-key-replace-before-deploy

# VAPID_PRIVATE_KEY: the private key (base64url). Keep this secret —
# it signs the VAPID JWT that authorises Web Push delivery to the push
# service. Never expose it to the browser or commit it.
VAPID_PRIVATE_KEY=dev-vapid-private-key-replace-before-deploy

# VAPID_SUBJECT: a mailto: or https: URI identifying the operator
# (required by RFC 8292 — push services may use it to contact you on
# delivery problems). E.g. mailto:hello@example.com or https://example.com.
VAPID_SUBJECT=mailto:hello@example.com

# --- Build identity (injected at image build) ------------------------
# Both default to 'dev' if unset. Typically populated via Docker
# build args (--build-arg BUILD_VERSION=v1.2.3 --build-arg
# BUILD_COMMIT=$(git rev-parse --short HEAD)) and read at runtime
# by /api/v1/health (version only) and /api/v1/admin/version
# (full identity, ADMIN_TOKEN-gated). Not a runtime knob — setting
# them via .env works for local experiments but is not the
# expected operator path.
# BUILD_VERSION=dev
# BUILD_COMMIT=dev
