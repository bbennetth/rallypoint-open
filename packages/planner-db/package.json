{
  "name": "@rallypoint/planner-db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/schema/index.js",
  "types": "dist/schema/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "planner:db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "planner:db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
