{
  "name": "rallypoint-core",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Rallypoint ID — open-source identity service. Monorepo root.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bbennetth/rallypoint-core.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test",
    "dev:stack": "bash scripts/dev.sh",
    "dev": "npm run dev --workspace=apps/id-api",
    "dev:web": "npm run dev --workspace=apps/id-web",
    "dev:events-api": "npm run dev --workspace=apps/events-api",
    "dev:events-web": "npm run dev --workspace=apps/events-web",
    "dev:lists-api": "npm run dev --workspace=apps/lists-api",
    "dev:lists-web": "npm run dev --workspace=apps/lists-web",
    "dev:money-api": "npm run dev --workspace=apps/money-api",
    "dev:money-web": "npm run dev --workspace=apps/money-web",
    "dev:www-web": "npm run dev --workspace=apps/www",
    "db:generate": "npm run db:generate -w @rallypoint/db",
    "db:migrate": "npm run db:migrate -w @rallypoint/db",
    "events:db:generate": "npm run events:db:generate -w @rallypoint/events-db",
    "events:db:migrate": "npm run events:db:migrate -w @rallypoint/events-db",
    "lists:db:generate": "npm run lists:db:generate -w @rallypoint/lists-db",
    "lists:db:migrate": "npm run lists:db:migrate -w @rallypoint/lists-db",
    "money:db:generate": "npm run money:db:generate -w @rallypoint/money-db",
    "money:db:migrate": "npm run money:db:migrate -w @rallypoint/money-db",
    "dev:planner-api": "npm run dev --workspace=apps/planner-api",
    "dev:planner-web": "npm run dev --workspace=apps/planner-web",
    "planner:db:generate": "npm run planner:db:generate -w @rallypoint/planner-db",
    "planner:db:migrate": "npm run planner:db:migrate -w @rallypoint/planner-db",
    "db:seed": "npm run db:seed -w @rallypoint/id-api",
    "bench:argon2": "tsx scripts/argon2-bench.ts",
    "bench:argon2-wasm": "tsx spikes/argon2-worker/node-bench.ts",
    "spike:d1": "vitest run --config spikes/d1-transactions/vitest.config.ts",
    "spike:crypto": "vitest run --config spikes/crypto-workers/vitest.config.ts",
    "test:d1": "vitest run --config apps/id-api/vitest.d1.config.ts",
    "test:d1:lists": "vitest run --config apps/lists-api/vitest.d1.config.ts",
    "test:d1:events": "vitest run --config apps/events-api/vitest.d1.config.ts",
    "test:d1:money": "vitest run --config apps/money-api/vitest.d1.config.ts",
    "test:d1:planner": "vitest run --config apps/planner-api/vitest.d1.config.ts",
    "test:workers": "vitest run --config packages/realtime/vitest.workers.config.ts",
    "test:objstore": "vitest run --config packages/object-store/vitest.workers.config.ts",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "e2e:headed": "playwright test -c e2e/playwright.config.ts --headed",
    "e2e:ui": "playwright test -c e2e/playwright.config.ts --ui"
  },
  "overrides": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "hash-wasm": "^4.12.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.45.0"
  }
}
