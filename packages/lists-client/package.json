{
  "name": "@rallypoint/lists-client",
  "version": "0.0.0",
  "description": "Typed client SDK for the Rallypoint Lists SDK API (/api/v1/sdk/lists/**). Consumed by events-web and third parties.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bbennetth/rallypoint-core.git",
    "directory": "packages/lists-client"
  },
  "type": "module",
  "main": "dist/index.js",
